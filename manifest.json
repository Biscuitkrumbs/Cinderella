/* Cindy Planner - Google Apps Script backend
   1. Create a new Google Sheet.
   2. Extensions > Apps Script.
   3. Paste this file.
   4. Run setup() once.
   5. Deploy > New deployment > Web app.
   6. Execute as: Me. Who has access: Anyone.
   7. Paste the Web App URL into js/config.js as API_URL.
*/

const SHEETS = {
  properties: 'Properties',
  bookings: 'Bookings',
  feedback: 'Feedback'
};

function setup() {
  const ss = SpreadsheetApp.getActive();
  createSheet_(ss, SHEETS.properties, ['id', 'name', 'notes', 'phone']);
  createSheet_(ss, SHEETS.bookings, ['id', 'propertyId', 'guest', 'checkIn', 'checkOut', 'notes', 'status']);
  createSheet_(ss, SHEETS.feedback, ['date', 'text']);

  const props = ss.getSheetByName(SHEETS.properties);
  if (props.getLastRow() === 1) {
    props.getRange(2, 1, 10, 4).setValues([
      ['p1', 'Ocean View', 'Gate 2468. Front door key safe.', '0412 345 678'],
      ['p2', 'Riverfront', 'Bins Tuesday. Spare sheets in hall cupboard.', ''],
      ['p3', 'White House', 'Owner prefers text message.', ''],
      ['p4', 'Beachside', 'Check BBQ and sand outside.', ''],
      ['p5', 'Mountain Retreat', 'Long driveway.', ''],
      ['p6', 'Sunset Villa', 'Restock coffee often.', ''],
      ['p7', 'Lakeside', 'Leave towels on lower shelf.', ''],
      ['p8', 'Pine Cottage', 'Dog sometimes next door.', ''],
      ['p9', 'Coastal Breeze', 'Check windows.', ''],
      ['p10', 'Harbour House', 'Key safe at side gate.', '']
    ]);
  }
}

function doGet() {
  return json_({ ok: true, app: 'Cindy Planner API' });
}

function doPost(e) {
  try {
    const body = JSON.parse(e.postData.contents || '{}');
    const action = body.action;
    if (action === 'getData') return json_(getData_());
    if (action === 'addBooking') return json_(upsertBooking_(body.booking));
    if (action === 'updateBooking') return json_(upsertBooking_(body.booking));
    if (action === 'deleteBooking') return json_(deleteBooking_(body.id));
    if (action === 'addFeedback') return json_(addFeedback_(body));
    return json_({ ok: false, error: 'Unknown action' });
  } catch (err) {
    return json_({ ok: false, error: String(err) });
  }
}

function getData_() {
  return {
    ok: true,
    properties: readObjects_(SHEETS.properties),
    bookings: readObjects_(SHEETS.bookings)
  };
}

function upsertBooking_(booking) {
  const sheet = SpreadsheetApp.getActive().getSheetByName(SHEETS.bookings);
  const rows = sheet.getDataRange().getValues();
  const headers = rows[0];
  const idCol = headers.indexOf('id');
  const values = headers.map(h => booking[h] || '');
  for (let r = 1; r < rows.length; r++) {
    if (rows[r][idCol] === booking.id) {
      sheet.getRange(r + 1, 1, 1, headers.length).setValues([values]);
      return { ok: true, updated: true };
    }
  }
  sheet.appendRow(values);
  return { ok: true, created: true };
}

function deleteBooking_(id) {
  const sheet = SpreadsheetApp.getActive().getSheetByName(SHEETS.bookings);
  const rows = sheet.getDataRange().getValues();
  const idCol = rows[0].indexOf('id');
  for (let r = rows.length - 1; r >= 1; r--) {
    if (rows[r][idCol] === id) sheet.deleteRow(r + 1);
  }
  return { ok: true };
}

function addFeedback_(body) {
  SpreadsheetApp.getActive().getSheetByName(SHEETS.feedback)
    .appendRow([body.date || new Date().toISOString(), body.text || '']);
  return { ok: true };
}

function readObjects_(sheetName) {
  const sheet = SpreadsheetApp.getActive().getSheetByName(sheetName);
  const values = sheet.getDataRange().getValues();
  if (values.length < 2) return [];
  const headers = values[0];
  return values.slice(1).filter(row => row.some(Boolean)).map(row => {
    const obj = {};
    headers.forEach((h, i) => obj[h] = formatValue_(row[i]));
    return obj;
  });
}

function formatValue_(value) {
  if (Object.prototype.toString.call(value) === '[object Date]') {
    return Utilities.formatDate(value, Session.getScriptTimeZone(), 'yyyy-MM-dd');
  }
  return value;
}

function createSheet_(ss, name, headers) {
  let sheet = ss.getSheetByName(name);
  if (!sheet) sheet = ss.insertSheet(name);
  sheet.clear();
  sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
  sheet.setFrozenRows(1);
  sheet.getRange(1, 1, 1, headers.length).setFontWeight('bold');
  sheet.autoResizeColumns(1, headers.length);
}

function json_(obj) {
  return ContentService.createTextOutput(JSON.stringify(obj))
    .setMimeType(ContentService.MimeType.JSON);
}
